{
  "name": "ghost-mail-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create ghost-mail-db",
    "db:init": "wrangler d1 execute ghost-mail-db --remote --file=./schema.sql",
    "db:init:local": "wrangler d1 execute ghost-mail-db --local --file=./schema.sql",
    "types": "wrangler types", 
    "secret": "wrangler secret put",
    "tail": "wrangler tail",
    "logs": "wrangler tail --format pretty"
  },
  "dependencies": {
    "postal-mime": "^2.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.0.0"
  }
}
